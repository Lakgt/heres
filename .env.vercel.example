# ============================================
# Heres Protocol — Vercel Environment Variables
# Copy these to Vercel Dashboard > Settings > Environment Variables
# <YOUR_...> 표시된 것만 직접 채우면 됩니다
# ============================================

# --- Chain selection ---
NEXT_PUBLIC_BLOCKCHAIN_TARGET=injective-evm
CRE_WALLET_SIGNATURE_SCHEME=injective-evm

# --- Solana ---
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROGRAM_ID=AmiL7vEZ2SpAuDXzdxC3sJMyjZqgacvwvvQdT3qosmsW
NEXT_PUBLIC_PLATFORM_FEE_RECIPIENT=Covn3moA8qstPgXPgueRGMSmi94yXvuDCWTjQVBxHpzb

# --- Injective EVM ---
NEXT_PUBLIC_INJECTIVE_EVM_RPC_URL=<YOUR_INJECTIVE_EVM_RPC_URL>
NEXT_PUBLIC_INJECTIVE_EVM_EXPLORER_URL=<YOUR_INJECTIVE_EVM_EXPLORER_URL>
NEXT_PUBLIC_INJECTIVE_EVM_CHAIN_ID=<YOUR_INJECTIVE_EVM_CHAIN_ID>
NEXT_PUBLIC_INJECTIVE_EVM_CAPSULE_MANAGER=<YOUR_INJECTIVE_EVM_CAPSULE_MANAGER>
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<YOUR_WALLETCONNECT_PROJECT_ID>

# --- Crank (auto-execute cron) ---
CRANK_WALLET_PRIVATE_KEY=<YOUR_CRANK_WALLET_PRIVATE_KEY>
INJECTIVE_EXECUTOR_PRIVATE_KEY=<YOUR_INJECTIVE_EXECUTOR_PRIVATE_KEY>
CRON_SECRET=<YOUR_RANDOM_STRING>
INJECTIVE_EXECUTOR_SCAN_LIMIT=250
INJECTIVE_EXECUTOR_MAX_EXECUTIONS=10
INJECTIVE_CRE_MAX_DISPATCHES=25

# --- CRE: Mock mode (Vercel에서는 실제 Chainlink 없이 self-callback) ---
CHAINLINK_CRE_WEBHOOK_URL=https://<YOUR_VERCEL_DOMAIN>/api/mock/cre
CHAINLINK_CRE_SIGNING_SECRET=<YOUR_RANDOM_STRING>
CHAINLINK_CRE_CALLBACK_SECRET=<YOUR_RANDOM_STRING>
MOCK_CRE_AUTO_CALLBACK=true
MOCK_CRE_CALLBACK_BASE_URL=https://<YOUR_VERCEL_DOMAIN>

# --- CRE: Real deployment (switch when Chainlink CRE workflow is approved and deployed) ---
# CHAINLINK_CRE_WEBHOOK_URL=<YOUR_DEPLOYED_CRE_WORKFLOW_ENDPOINT>
# MOCK_CRE_AUTO_CALLBACK=false
